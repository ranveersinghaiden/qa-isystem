# .env.example — copy to .env at DEPLOY_PATH on your server and fill in values.
# This file documents every variable that docker-compose.prod.yml reads.
# Never commit the real .env file to source control.

# ── Container registry ────────────────────────────────────────────────────────
# GitHub org or user that owns the GHCR packages (no trailing slash).
# Example: GHCR_ORG=acme-corp  →  images pull from ghcr.io/acme-corp/qa-isystem/...
GHCR_ORG=

# ── Image tags (optional — defaults to "latest") ─────────────────────────────
# The CD workflow overwrites these with the SHA-based tag from the build.
PR_SERVICE_TAG=latest
IMPACT_SERVICE_TAG=latest
STRATEGY_SERVICE_TAG=latest

# ── strategy-service: target test repository ──────────────────────────────────
# The repository that strategy-service clones to build the coverage index.
# Leave blank to run without test repo (coverage will be UNKNOWN).
TARGET_REPO_URL=
TARGET_REPO_TOKEN=
TARGET_REPO_USERNAME=

# ── impact-service: AI last-resort evaluator ─────────────────────────────────
# Set AIQA_AI_ENABLED=true and provide an API key to enable AI refinement.
AIQA_AI_ENABLED=false
AIQA_AI_API_KEY=
AIQA_AI_MODEL=gpt-4o-mini

# ── strategy-service: GitHub webhook ─────────────────────────────────────────
# HMAC-SHA256 secret set in GitHub Repository Settings → Webhooks.
# The strategy-service uses this to verify that webhook events really came from GitHub.
# Leave blank in local dev (signature check is skipped with a warning).
GITHUB_WEBHOOK_SECRET=

# ── Kafka (production) ────────────────────────────────────────────────────────
# Hostname or IP that Kafka advertises to clients outside the Docker network.
KAFKA_HOST=localhost
