# .env.example — copy to .env at DEPLOY_PATH on your server and fill in values.
# This file documents every variable that docker-compose.prod.yml reads.
# Never commit the real .env file to source control.

# ── Docker image tags (set automatically by the CD workflow) ──────────────────
PR_SERVICE_IMAGE=ghcr.io/your-org/qa-isystem/pr-service:latest
IMPACT_SERVICE_IMAGE=ghcr.io/your-org/qa-isystem/impact-service:latest
STRATEGY_SERVICE_IMAGE=ghcr.io/your-org/qa-isystem/strategy-service:latest

# ── strategy-service: target test repository ──────────────────────────────────
# The repository that strategy-service clones to build the coverage index.
# Leave blank to run without test repo (coverage will be UNKNOWN).
TARGET_REPO_URL=https://github.com/your-org/your-test-repo
TARGET_REPO_TOKEN=ghp_your_personal_access_token
TARGET_REPO_USERNAME=your_github_username

# ── impact-service: AI last-resort evaluator ─────────────────────────────────
# Set AIQA_AI_ENABLED=true and provide an API key to enable AI refinement.
AIQA_AI_ENABLED=false
AIQA_AI_API_KEY=
AIQA_AI_MODEL=gpt-4o-mini

